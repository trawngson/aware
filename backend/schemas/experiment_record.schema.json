{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aware.local/schemas/experiment_record.schema.json",
  "title": "AWARE experiment record",
  "type": "object",
  "required": [
    "schema_version", "run_id", "run_kind", "status", "model", "ontology_version",
    "source_manifest_version", "split_version", "code_revision",
    "training", "environment", "outputs", "metrics"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
    "run_kind": {"enum": ["full", "smoke"]},
    "status": {"enum": ["planned", "running", "completed", "failed", "cancelled"]},
    "model": {"enum": ["yolo26n.pt", "yolo26s.pt"]},
    "ontology_version": {"const": "aware-ontology-v1"},
    "source_manifest_version": {"const": "aware-sources-v1"},
    "training": {
      "type": "object",
      "required": [
        "image_size", "seed", "deterministic", "epochs", "patience", "batch",
        "optimizer", "initial_learning_rate", "config_file"
      ],
      "properties": {
        "image_size": {"const": 640},
        "seed": {"const": 26},
        "deterministic": {"const": true},
        "epochs": {"enum": [1, 200]},
        "patience": {"const": 40},
        "batch": {"const": 64},
        "optimizer": {"const": "AdamW"},
        "initial_learning_rate": {"const": 0.001},
        "config_file": {"const": "configs/training/v1_controlled.yaml"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"run_kind": {"const": "smoke"}}},
      "then": {"properties": {"training": {"properties": {"epochs": {"const": 1}}}}},
      "else": {"properties": {"training": {"properties": {"epochs": {"const": 200}}}}}
    }
  ],
  "additionalProperties": true
}
